<?xml version="1.0" encoding="utf-8"?>
<LanguageData>
  <!--English=[Hauts&apos; Offbeat Psycasts] active.-->
  <HVP_Initialize>[Hauts' Offbeat Psycasts] 활성화.</HVP_Initialize>
  <!--English=Forewarned!-->
  <HVP_WarningBlock>경고됨!</HVP_WarningBlock>
  <!--English=Word of Sterility removed the {0} condition from {1}!-->
  <HVP_RemovedHediff>멸균의 단어로 {1}의 {0} 상태가 제거되었습니다!</HVP_RemovedHediff>
  <!--English=Cancel paralysis links-->
  <HVP_NoParalysisLabel>마비 연결 취소</HVP_NoParalysisLabel>
  <!--English=Destroys all paralysis links being maintained by this caster.-->
  <HVP_NoParalysisText>이 시전자가 유지하고 있는 모든 마비 연결을 취소합니다.</HVP_NoParalysisText>
  <!--English=Recall {PAWN_nameDef}-->
  <HVP_RecallLabel>{PAWN_nameDef} 귀환</HVP_RecallLabel>
  <!--English=Teleports {PAWN_nameDef} to the linked tether skipgate.-->
  <HVP_RecallText>{PAWN_nameDef}(을)를 연결된 고정 관문으로 순간이동시킵니다.</HVP_RecallText>
  <!--English=Teleports {PAWN_nameDef} to the linked tether portal.-->
  <HVP_RecallTextFantasy>{PAWN_nameDef}(을)를 연결된 고정 포탈로 순간이동시킵니다.</HVP_RecallTextFantasy>
  <!--English=Cancel psyphon links-->
  <HVP_NoPsyphonLabel>흡수 연결 취소</HVP_NoPsyphonLabel>
  <!--English=Destroys all psyphon links being maintained by this caster.-->
  <HVP_NoPsyphonText>이 시전자가 유지하고 있는 모든 흡수 연결을 취소합니다.</HVP_NoPsyphonText>
  <!--English=Cancel booster links-->
  <HVP_NoBoosterLabel>강화 연결 취소</HVP_NoBoosterLabel>
  <!--English=Destroys all booster links being maintained by this caster.-->
  <HVP_NoBoosterText>이 시전자가 유지하고 있는 모든 강화 연결을 취소합니다.</HVP_NoBoosterText>
  <!--English=Retrieve items in vault skip-->
  <HVP_StorageDumpLabel>금고 공간도약 물품 회수</HVP_StorageDumpLabel>
  <!--English=Skips all items stored by vault Skip to the caster&apos;s location.-->
  <HVP_StorageDumpText>금고 공간도약으로 보관된 모든 물품을 시전자의 위치로 순간이동시킵니다.</HVP_StorageDumpText>
  <!--English=End rejuvenation-->
  <HVP_UndoRJLabel>재생 종료</HVP_UndoRJLabel>
  <!--English=Ends the effects of the rejuvenation skip on {PAWN_nameDef}.-->
  <HVP_UndoRJText>{PAWN_nameDef}에게 적용된 재생 소환 효과를 종료합니다.</HVP_UndoRJText>
  <!--English=Ends the effects of the rejuvenation spell on {PAWN_nameDef}.-->
  <HVP_UndoRJTextFantasy>{PAWN_nameDef}에게 적용된 재생 주문 효과를 종료합니다.</HVP_UndoRJTextFantasy>
  <!--English=Cancel tornado link-->
  <HVP_NoTornadoLabel>토네이도 연결 취소</HVP_NoTornadoLabel>
  <!--English=Relinquishes control over the tornado currently linked to this caster. If the tornado is at least three hours old, this will destroy it; otherwise, it will roam around until it reaches three hours of age, then fade away.-->
  <HVP_NoTornadoText>현재 이 시전자와 연결된 토네이도의 제어권을 포기합니다. 토네이도가 생성된 지 3시간이 지났다면 즉시 소멸하며, 그렇지 않다면 생성된 지 3시간이 지날 때까지 사방을 배회하다가 사라집니다.</HVP_NoTornadoText>
  <!--English=Psychically meld to-->
  <HVP_MeldInto>대상과 정신적 융합</HVP_MeldInto>
  <!--English=Induce psychic melding of-->
  <HVP_Meld>정신적 융합 유도</HVP_Meld>
  <!--English=Psyfocus cost per pawn body size or building footprint size-->
  <HVP_EvictionSkipCosts>폰의 신체 크기 또는 구조물 크기당 초집중 소모량</HVP_EvictionSkipCosts>
  <!--English=Mana cost per pawn body size or building footprint size-->
  <HVP_EvictionSkipCostsF>폰의 신체 크기 또는 구조물 크기당 마나 소모량</HVP_EvictionSkipCostsF>
  <!--English=Cannot perform transfer-->
  <HVP_CannotTransfer>전송 불가</HVP_CannotTransfer>
  <!--English=has no need for sleep or energy-->
  <HVP_NoTransferrableEnergy>수면이나 전력이 필요하지 않습니다.</HVP_NoTransferrableEnergy>
  <!--English=has no skills-->
  <HVP_NoTransferrableSkills>기술이 없습니다.</HVP_NoTransferrableSkills>
  <!--English=donor has no betterーlevel skills than recipient-->
  <HVP_NoLowerSkills>주는 대상의 기술 등급이 받는 대상보다 높지 않습니다.</HVP_NoLowerSkills>
  <!--English=target is already affected by tether skip-->
  <HVP_TargetAlreadyTethered>대상이 이미 고정된 공간도약의 영향을 받고 있습니다.</HVP_TargetAlreadyTethered>
  <!--English=lightning cannot strike under a roof-->
  <HVP_RoofedLightning>지붕 아래에는 벼락을 칠 수 없습니다.</HVP_RoofedLightning>
  <!--English=target must be a psycaster-->
  <HVP_NotAPsycaster>대상은 초능력자여야 합니다.</HVP_NotAPsycaster>
  <!--English=target must be a spellcaster-->
  <HVP_NotAPsycasterF>대상은 주문 시전자여야 합니다.</HVP_NotAPsycasterF>
  <!--English=target must be a chunk, resource, or food item other than a fertilized egg-->
  <HVP_WrongItemType>대상은 덩어리, 자원, 유정란이 아닌 음식이여야 합니다.</HVP_WrongItemType>
  <!--English=too valuable (limit {0} silver value)-->
  <HVP_ItemTooExpensive>가치가 너무 높습니다. (최대 {0})</HVP_ItemTooExpensive>
  <!--English=no ground at target point-->
  <HVP_InSpaceNoOneCanHearYouQuake>대상 지점에 지반이 없습니다.</HVP_InSpaceNoOneCanHearYouQuake>
  <!--English=aerial drops cannot land at the target location-->
  <HVP_NotGoodDropSpot>공중 낙하물이 대상 위치에 착륙할 수 없습니다.</HVP_NotGoodDropSpot>
  <!--English=target has nothing to steal-->
  <HVP_TargetLacksStealables>대상이 훔칠 물품을 가지고 있지 않습니다.</HVP_TargetLacksStealables>
  <!--English=must use a chunk-->
  <HVP_NotAChunk>덩어리에 사용해야 합니다.</HVP_NotAChunk>
  <!--English=overhead mountain blocks meteoroids-->
  <HVP_MeteorMountain>산 지붕이 운석을 차단합니다.</HVP_MeteorMountain>
  <!--English=targeted roof is unmodifiable-->
  <HVP_InvincibleRoof>대상 지붕은 수정할 수 없습니다.</HVP_InvincibleRoof>
  <!--English=target space cannot support a roof-->
  <HVP_WhereYouGonnaPutThatRoofEh>대상 공간은 지붕을 지탱할 수 없습니다.</HVP_WhereYouGonnaPutThatRoofEh>
  <!--English=can&apos;t be used in an underground map-->
  <HVP_YoureUnderground>지하 지도에서는 사용할 수 없습니다.</HVP_YoureUnderground>
  <!--English=target must be destructible-->
  <HVP_MustBeVincible>대상이 파괴 가능해야 합니다.</HVP_MustBeVincible>
  <!--English={PSYCASTNAME} needs {0} psyfocus to evict the target but {CASTERNAME} only has {1} psyfocus.-->
  <HVP_CommandPsycastNotEnoughPsyfocusForSize>대상을 추방하려면 {PSYCASTNAME}에 {0}의 초집중이 필요하지만 {CASTERNAME}(은)는 {1}의 초집중을 가지고 있습니다.</HVP_CommandPsycastNotEnoughPsyfocusForSize>
  <!--English={PSYCASTNAME} needs {0} mana to evict the target but {CASTERNAME} only has {1} mana.-->
  <HVP_CommandPsycastNotEnoughPsyfocusForSizeF>대상을 추방하려면 {PSYCASTNAME}에 {0}의 마나가 필요하지만 {CASTERNAME}(은)는 {1}의 마나를 가지고 있습니다.</HVP_CommandPsycastNotEnoughPsyfocusForSizeF>
  <!--English=too many hives already spawned-->
  <HVP_TooManyHivesOnMap>지도에 너무 많은 군락이 생성되어 있습니다.</HVP_TooManyHivesOnMap>
  <!--English=insufficient room for a hive there-->
  <HVP_HiveBlocked>대상 지점은 군락이 들어설 공간이 부족합니다.</HVP_HiveBlocked>
  <!--English=too cold for hives to spawn there-->
  <HVP_HiveTooCold>대상 지점은 너무 추워서 군락이 생성될 수 없습니다.</HVP_HiveTooCold>
  <!--English=Storing the following:-->
  <HVP_StoringTheFollowing>다음 항목 보관 중:</HVP_StoringTheFollowing>
  <!--English=... and {0} more-->
  <HVP_AndYetMoreStored>... 외 {0}개</HVP_AndYetMoreStored>
  <!--English=The psyphon link established by {0} was broken by {1}, stunning both of them.-->
  <HVP_PsyphonBroken>{0}(이)가 구축한 흡수 연결을 {1}(이)가 끊어내어, 두 사람 모두 기절했습니다.</HVP_PsyphonBroken>
  <!--English=Due to the death of {PAWN_nameDef}, everything {PAWN_pronoun} was carrying in {PAWN_possessive} vault skip was ejected.-->
  <HVP_VaultDeath>{PAWN_nameDef}의 죽음으로 인해 {PAWN_pronoun}(이)가 금고 공간도약으로 보관되어 있던 모든 물품이 밖으로 배출되었습니다.</HVP_VaultDeath>
  <!--English=Some items have been irretrievably lost.-->
  <HVP_VaultDeathNoWarranty>일부 물품은 영구적으로 소실되었습니다.</HVP_VaultDeathNoWarranty>
  <!--English=The summoned drop pod depressurized during atmospheric entry, rendering its contents to ash.-->
  <HVP_DropPodDefault>소환된 수송 포드가 대기권 진입 중 압력을 견디지 못하고 감압되어 내부의 내용물이 재가 되었습니다.</HVP_DropPodDefault>
  <!--English=A psycaster belonging to the {0} faction used Word of Safety to kidnap {1}.-->
  <HVP_PsychicKidnapping>{0} 세력의 초능력자가 안전의 단어를 사용하여 {1}(을)를 납치했습니다.</HVP_PsychicKidnapping>
  <!--English=Choose a blessing to grant {0}.-->
  <HVP_BlessingMenu>{0}(이)가 부여받을 축복을 선택하세요.</HVP_BlessingMenu>
  <!--English=Choose a blessing to grant all affected creatures.-->
  <HVP_BlessingMenuMulti>영향을 받는 모든 생명체에게 부여할 축복을 선택하세요.</HVP_BlessingMenuMulti>
  <!--English=Amount of psytrainers sold by traders-->
  <HVP_SettingPSM>상인이 파는 초월교육 혈청의 수</HVP_SettingPSM>
  <!--English=Scales the amount of psytrainers traders will sell; at 2x, a trader who would ordinarily sell 1ー3 psytrainers will sell 2ー6. This won&apos;t cause traders who don&apos;t sell psytrainers to start doing so.-->
  <HVP_TooltipPsytrainerSaleMulti>상인들이 파는 초월교육 혈청의 수를 조절합니다. 2배로 설정하면, 보통 1-3개의 초월교육 혈청을 팔던 상인이 2-6개를 팔게 됩니다. 이 설정으로 인해 기존에 초월교육 혈청을 팔지 않던 상인이 새로 초월교육 혈청을 팔기 시작하지는 않습니다.</HVP_TooltipPsytrainerSaleMulti>
  <!--English=Psycasts learned per psylink level-->
  <HVP_SettingPLPL>정신력 증폭 등급당 배우는 초능력 개수</HVP_SettingPLPL>
  <!--English=Whenever a pawn gains a psylink level, they will gain this many psycasts (1 is normal). This will not apply retroactively. If you&apos;re using mods that enable psylink levels above 6, note that this setting will not apply to those levels.-->
  <HVP_TooltipSettingPLPL>폰이 정신력 증폭 등급을 얻을 때마다, 이 수치만큼의 초능력을 학습합니다. (기본값은 1개) 기존에 획득한 등급에는 소급 적용되지 않습니다. 만약 정신력 증폭 등급을 6단계 이상으로 확장해 주는 다른 모드를 사용하는 경우, 6단계를 초과하는 등급에는 이 설정이 적용되지 않으니 주의하세요.</HVP_TooltipSettingPLPL>
  <!--English=Buff the &quot;Flashstorm&quot; psycast-->
  <HVP_SettingBuffFlashstorm>"섬광폭풍" 초능력 강화</HVP_SettingBuffFlashstorm>
  <!--English=Dramatically increases the number of lightning strikes caused by the Flashstorm psycast, and causes some of them to have increased damage and armor penetration. Does not affect natural flashstorms. Does not retroactively apply to Flashstorms that have already been cast.-->
  <HVP_TooltipBuffFlashstorm>섬광폭풍 초능력으로 인해 발생하는 낙뢰의 빈도를 극적으로 증가시키며, 일부 낙뢰는 피해량과 방어 관통력이 증가합니다. 자연 발생한 섬광폭풍에는 영향을 주지 않습니다. 이미 시전된 섬광폭풍에는 소급 적용되지 않습니다.</HVP_TooltipBuffFlashstorm>
</LanguageData>